{
  "expo": {
    "name": "TransVigo Driver",
    "slug": "transvigo-driver",
    "scheme": "transvigo-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.transvigo.driver"
    },
    "android": {
      "package": "com.transvigo.driver",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-camera",
        { "cameraPermission": "TransVigo needs camera access for odometer and receipt photos" }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TransVigo uses your location to auto-fill incident reports"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#1B2D6B",
          "androidMode": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
